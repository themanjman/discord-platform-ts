{
  "name": "@discord-platform-ts/discord-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord bot application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^16.3.1",
    "tsyringe": "^4.8.0",
    "reflect-metadata": "^0.1.14",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.10.6",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.39.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
