# Discord Bot Configuration
# Copy this file to .env and fill in your values

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=
CLIENT_ID=
SUPPORT_URL=

# Bot Settings
COMMAND_PREFIX=!
BOT_NAME=Discord Bot
VERSION=1.0.0

# Logging
LOG_LEVEL=info
LOG_PROVIDER=winston

# Persistence (relative to apps/discord-bot when running locally)
DATA_DIR=data

# Optional - Disable Commands
# Comma-separated list of command names to disable
# Example: DISABLED_SLASH_COMMANDS=info,help
DISABLED_SLASH_COMMANDS=
DISABLED_PREFIX_COMMANDS=

# Optional - Disable All Commands
# Set to 'true' or '1' to disable all commands of that type
DISABLE_ALL_SLASH_COMMANDS=false
DISABLE_ALL_PREFIX_COMMANDS=false